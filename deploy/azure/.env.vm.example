# Domain and routing
ROADLYTICS_DOMAIN=your-domain.example.com

# Azure Blob
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=roadlytics

# Backend runtime
ROADLYTICS_DEBUG=false
ROADLYTICS_WORKER_CONCURRENCY=1
ROADLYTICS_MODEL_WEIGHTS_DIR=/app/model_weights
ROADLYTICS_OSM_DIR=/app/data/osm_roads
ROADLYTICS_SEG_WEIGHTS=
ROADLYTICS_CLS_WEIGHTS=

# Frontend build-time settings
NEXT_PUBLIC_API_BASE_URL=https://your-domain.example.com
NEXT_PUBLIC_BASEMAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
NEXT_PUBLIC_BASEMAP_ATTRIBUTION=&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors

