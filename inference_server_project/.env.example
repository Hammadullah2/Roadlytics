# SentinelHub credentials — get these from https://apps.sentinel-hub.com/dashboard
SH_CLIENT_ID=your-client-id-here
SH_CLIENT_SECRET=your-client-secret-here

# Optional: specific instance ID if using dedicated instance
# SH_INSTANCE_ID=your-instance-id

# Paths — weights directory (contains road segmentation.pth, road_condition_model.pth)
ARTIFACTS_DIR=../weights
OUTPUT_DIR=./outputs

# Redis broker for Celery
REDIS_URL=redis://localhost:6379/0

# Device: cuda or cpu
DEVICE=cuda

# Optional: CUDA device selection (only used if DEVICE=cuda)
# CUDA_VISIBLE_DEVICES=0
