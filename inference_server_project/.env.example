# Inference server VPS environment — copy to .env and fill in real values.
# Used by: docker-compose.vps.yml (inference, inference-worker services)

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
# IMPORTANT: no trailing /rest/v1/ — the Python client appends this automatically
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Backend callback ──────────────────────────────────────────────────────────
# Where the VPS posts job progress updates (Vercel backend URL in production)
BACKEND_CALLBACK_URL=https://backend-ivory-omega.vercel.app
# Must match INTERNAL_SECRET in the Go backend env (Vercel + local)
INTERNAL_SECRET=<64-char-hex-secret>

# ── AWS S3 (job output storage) ───────────────────────────────────────────────
S3_BUCKET_NAME=roadlytics-outputs
S3_REGION=eu-north-1
S3_ACCESS_KEY_ID=<aws-access-key-id>
S3_SECRET_ACCESS_KEY=<aws-secret-access-key>
S3_PUBLIC_BASE_URL=https://<bucket>.s3.<region>.amazonaws.com

# ── SentinelHub (satellite imagery fetch) ─────────────────────────────────────
# Get from: https://apps.sentinel-hub.com/dashboard → OAuth clients
SH_CLIENT_ID=<sentinelhub-client-id>
SH_CLIENT_SECRET=<sentinelhub-client-secret>
SH_INSTANCE_ID=<sentinelhub-instance-id>

# ── Runtime ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
DEVICE=cpu
ARTIFACTS_DIR=../weights
OUTPUT_DIR=./outputs
