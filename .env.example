# ── Supabase PostgreSQL ────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → Database → Connection string (Transaction mode)
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:5432/postgres

# ── Supabase Project ───────────────────────────────────────────────────────────
# Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── Supabase Storage Buckets ───────────────────────────────────────────────────
# Create these buckets in Supabase Dashboard → Storage
STORAGE_BUCKET_GEOJSON=geojson-uploads
STORAGE_BUCKET_IMAGES=satellite-images
STORAGE_BUCKET_REPORTS=reports

# ── Backend Server ─────────────────────────────────────────────────────────────
PORT=8080
SERVER_PORT=8080
SERVER_ENV=development
FRONTEND_URL=http://localhost:5173

# Random secret shared between backend and inference callbacks — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SECRET=replace_with_random_hex_secret

# ── Frontend (Vite build args + dev server) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ── Inference Server ───────────────────────────────────────────────────────────
# Set to http://inference:8000 when running with --profile inference (Docker DNS).
# Leave unset to run backend + frontend without inference (jobs stay queued).
INFERENCE_SERVER_URL=http://inference:8000
INFERENCE_DEVICE=cpu

# ── SentinelHub (required for inference server fetch-and-run mode) ─────────────
# Get credentials at: https://apps.sentinel-hub.com/dashboard → OAuth clients
SH_CLIENT_ID=your_sentinelhub_client_id
SH_CLIENT_SECRET=your_sentinelhub_client_secret
SH_INSTANCE_ID=your_sentinelhub_instance_id

# ── Planet Copernicus API (optional fallback for satellite imagery) ─────────────
# Get key at: https://www.planet.com/account/#/user-settings
PLANET_API_KEY=your_planet_api_key
