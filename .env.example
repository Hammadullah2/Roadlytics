# ══════════════════════════════════════════════════════════════════════════════
# Roadlytics environment template
#
# Deployment split:
#   Vercel  → backend (Go API) + frontend (React/Vite)
#   VPS     → inference server (FastAPI + Celery + Redis) via Docker
#   Supabase → database, storage, auth, realtime
#
# Copy this file to .env and fill in real values.
# For VPS-only env vars see inference_server_project/.env.vps.example
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase (required by backend AND inference server) ───────────────────────
# Supabase Dashboard → Settings → Database → Connection string (Transaction mode)
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-region.pooler.supabase.com:5432/postgres

# Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_jwt_secret_here

# ── Supabase Storage Buckets ───────────────────────────────────────────────────
# Create these in Supabase Dashboard → Storage → New bucket
STORAGE_BUCKET_GEOJSON=geojson-uploads
STORAGE_BUCKET_IMAGES=satellite-images
STORAGE_BUCKET_REPORTS=reports
# Bucket where inference output files (GeoJSON, PDFs, shapefiles) are uploaded
# by the VPS inference server directly.  Create in Supabase Dashboard → Storage.
STORAGE_BUCKET_OUTPUTS=inference-outputs

# ── Backend (Vercel) ──────────────────────────────────────────────────────────
PORT=8080
SERVER_PORT=8080
SERVER_ENV=development

# Allowed CORS origin — set to your Vercel frontend URL in production
FRONTEND_URL=http://localhost:5173

# Random secret shared between the Vercel backend and the VPS inference server.
# The inference server sends this in X-Internal-Secret when calling the backend
# callback endpoint.  Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_SECRET=replace_with_random_hex_secret

# ── Inference server URL (used by backend to dispatch new jobs) ───────────────
# In production: https://inference.yourdomain.com
# In local dev:  http://localhost:8000
INFERENCE_SERVER_URL=http://localhost:8000

# ── Frontend (Vite build-time env vars) ───────────────────────────────────────
# In Vercel these are set under Project → Settings → Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# Backend API base URL — set to your Vercel backend deployment URL in production
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ── VPS Inference server (set these in inference_server_project/.env) ─────────
# The VPS needs SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY to write directly to
# the database and upload output files to Supabase Storage.
# It also needs BACKEND_CALLBACK_URL + INTERNAL_SECRET to notify the backend on
# completion.
#
# BACKEND_CALLBACK_URL=https://your-backend.vercel.app
# INFERENCE_DEVICE=cpu   # set to "cuda" if the VPS has an NVIDIA GPU

# ── SentinelHub (required on VPS for fetch-and-run jobs) ─────────────────────
SH_CLIENT_ID=your_sentinelhub_client_id
SH_CLIENT_SECRET=your_sentinelhub_client_secret
SH_INSTANCE_ID=your_sentinelhub_instance_id

# ── Planet Copernicus API (optional satellite imagery fallback) ───────────────
PLANET_API_KEY=your_planet_api_key
